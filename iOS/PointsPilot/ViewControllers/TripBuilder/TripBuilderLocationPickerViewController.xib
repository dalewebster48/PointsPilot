<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24765" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24743"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="TripBuilderLocationPickerViewController" customModule="PointsPilot" customModuleProvider="target">
            <connections>
                <outlet property="view" destination="root" id="ov"/>
                <outlet property="collectionView" destination="cv" id="o1"/>
                <outlet property="activityIndicator" destination="spinner" id="o2"/>
                <outlet property="summaryBanner" destination="banner" id="o3"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="root">
            <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <viewLayoutGuide key="safeArea" id="rootSafe"/>
            <subviews>
                <collectionView clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleToFill" dataMode="none" translatesAutoresizingMaskIntoConstraints="NO" id="cv">
                    <rect key="frame" x="16" y="0.0" width="361" height="852"/>
                    <collectionViewFlowLayout key="collectionViewLayout" minimumLineSpacing="8" minimumInteritemSpacing="8" id="cvfl">
                        <size key="itemSize" width="100" height="32"/>
                        <size key="headerReferenceSize" width="0.0" height="0.0"/>
                        <size key="footerReferenceSize" width="0.0" height="0.0"/>
                    </collectionViewFlowLayout>
                </collectionView>
                <activityIndicatorView opaque="NO" contentMode="scaleToFill" horizontalHuggingPriority="750" verticalHuggingPriority="750" hidesWhenStopped="YES" style="medium" translatesAutoresizingMaskIntoConstraints="NO" id="spinner">
                    <rect key="frame" x="189" y="418" width="20" height="20"/>
                </activityIndicatorView>
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="banner" customClass="TripBuilderSummary" customModule="PointsPilot" customModuleProvider="target">
                    <rect key="frame" x="16" y="744" width="361" height="84"/>
                </view>
            </subviews>
            <constraints>
                <constraint firstItem="cv" firstAttribute="leading" secondItem="root" secondAttribute="leading" constant="16" id="c1"/>
                <constraint firstAttribute="trailing" secondItem="cv" secondAttribute="trailing" constant="16" id="c2"/>
                <constraint firstItem="cv" firstAttribute="top" secondItem="root" secondAttribute="topMargin" id="c3"/>
                <constraint firstAttribute="bottom" secondItem="cv" secondAttribute="bottom" id="c4"/>
                <constraint firstItem="spinner" firstAttribute="centerX" secondItem="root" secondAttribute="centerX" id="sc1"/>
                <constraint firstItem="spinner" firstAttribute="centerY" secondItem="root" secondAttribute="centerY" id="sc2"/>
                <constraint firstItem="banner" firstAttribute="leading" secondItem="root" secondAttribute="leading" constant="16" id="b1"/>
                <constraint firstAttribute="trailing" secondItem="banner" secondAttribute="trailing" constant="16" id="b2"/>
                <constraint firstItem="rootSafe" firstAttribute="bottom" secondItem="banner" secondAttribute="bottom" constant="12" id="b3"/>
            </constraints>
        </view>
    </objects>
</document>
