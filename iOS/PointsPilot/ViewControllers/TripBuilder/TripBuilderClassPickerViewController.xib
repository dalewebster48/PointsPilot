<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24765" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24743"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="TripBuilderClassPickerViewController" customModule="PointsPilot" customModuleProvider="target">
            <connections>
                <outlet property="view" destination="root" id="ov"/>
                <outlet property="classCollectionView" destination="classCV" id="o1"/>
                <outlet property="optionsContainer" destination="options" id="o2"/>
                <outlet property="dealsOnlySwitch" destination="dealsSwitch" id="o3"/>
                <outlet property="maxCostTextField" destination="costField" id="o4"/>
                <outlet property="maxCostContainer" destination="costContainer" id="o5"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="root">
            <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <collectionView clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleToFill" dataMode="none" translatesAutoresizingMaskIntoConstraints="NO" id="classCV">
                    <rect key="frame" x="16" y="16" width="361" height="48"/>
                    <constraints>
                        <constraint firstAttribute="height" constant="48" id="cvh"/>
                    </constraints>
                    <collectionViewFlowLayout key="collectionViewLayout" minimumLineSpacing="8" minimumInteritemSpacing="8" id="cvfl">
                        <size key="itemSize" width="100" height="32"/>
                    </collectionViewFlowLayout>
                </collectionView>
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="options">
                    <rect key="frame" x="16" y="80" width="361" height="120"/>
                    <subviews>
                        <!-- Deals only row -->
                        <stackView opaque="NO" contentMode="scaleToFill" alignment="center" spacing="8" translatesAutoresizingMaskIntoConstraints="NO" id="dealsStack">
                            <rect key="frame" x="0.0" y="0.0" width="361" height="31"/>
                            <subviews>
                                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" text="Only show deals" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="dealsLabel">
                                    <rect key="frame" x="0.0" y="5.5" width="302" height="20"/>
                                    <fontDescription key="fontDescription" type="system" pointSize="15"/>
                                </label>
                                <switch opaque="NO" contentMode="scaleToFill" horizontalHuggingPriority="750" verticalHuggingPriority="750" contentHorizontalAlignment="center" contentVerticalAlignment="center" translatesAutoresizingMaskIntoConstraints="NO" id="dealsSwitch">
                                    <rect key="frame" x="310" y="0.0" width="51" height="31"/>
                                    <connections>
                                        <action selector="dealsOnlyChanged:" destination="-1" eventType="valueChanged" id="dsa"/>
                                    </connections>
                                </switch>
                            </subviews>
                        </stackView>
                        <!-- Max cost row -->
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="costContainer">
                            <rect key="frame" x="0.0" y="47" width="361" height="60"/>
                            <subviews>
                                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Max Cost" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="costLabel">
                                    <rect key="frame" x="0.0" y="0.0" width="100" height="20"/>
                                    <fontDescription key="fontDescription" type="system" pointSize="15"/>
                                </label>
                                <textField opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="left" contentVerticalAlignment="center" borderStyle="roundedRect" placeholder="Points" textAlignment="natural" minimumFontSize="17" translatesAutoresizingMaskIntoConstraints="NO" id="costField">
                                    <rect key="frame" x="0.0" y="28" width="361" height="32"/>
                                    <fontDescription key="fontDescription" type="system" pointSize="15"/>
                                    <textInputTraits key="textInputTraits" keyboardType="numberPad"/>
                                </textField>
                            </subviews>
                            <constraints>
                                <constraint firstItem="costLabel" firstAttribute="leading" secondItem="costContainer" secondAttribute="leading" id="cc1"/>
                                <constraint firstItem="costLabel" firstAttribute="top" secondItem="costContainer" secondAttribute="top" id="cc2"/>
                                <constraint firstItem="costField" firstAttribute="leading" secondItem="costContainer" secondAttribute="leading" id="cc3"/>
                                <constraint firstAttribute="trailing" secondItem="costField" secondAttribute="trailing" id="cc4"/>
                                <constraint firstItem="costField" firstAttribute="top" secondItem="costLabel" secondAttribute="bottom" constant="8" id="cc5"/>
                                <constraint firstAttribute="bottom" secondItem="costField" secondAttribute="bottom" id="cc6"/>
                            </constraints>
                        </view>
                    </subviews>
                    <constraints>
                        <constraint firstItem="dealsStack" firstAttribute="leading" secondItem="options" secondAttribute="leading" id="oc1"/>
                        <constraint firstAttribute="trailing" secondItem="dealsStack" secondAttribute="trailing" id="oc2"/>
                        <constraint firstItem="dealsStack" firstAttribute="top" secondItem="options" secondAttribute="top" id="oc3"/>
                        <constraint firstItem="costContainer" firstAttribute="leading" secondItem="options" secondAttribute="leading" id="oc4"/>
                        <constraint firstAttribute="trailing" secondItem="costContainer" secondAttribute="trailing" id="oc5"/>
                        <constraint firstItem="costContainer" firstAttribute="top" secondItem="dealsStack" secondAttribute="bottom" constant="16" id="oc6"/>
                    </constraints>
                </view>
            </subviews>
            <constraints>
                <constraint firstItem="classCV" firstAttribute="leading" secondItem="root" secondAttribute="leading" constant="16" id="rc1"/>
                <constraint firstAttribute="trailing" secondItem="classCV" secondAttribute="trailing" constant="16" id="rc2"/>
                <constraint firstItem="classCV" firstAttribute="top" secondItem="root" secondAttribute="topMargin" constant="16" id="rc3"/>
                <constraint firstItem="options" firstAttribute="leading" secondItem="root" secondAttribute="leading" constant="16" id="rc4"/>
                <constraint firstAttribute="trailing" secondItem="options" secondAttribute="trailing" constant="16" id="rc5"/>
                <constraint firstItem="options" firstAttribute="top" secondItem="classCV" secondAttribute="bottom" constant="16" id="rc6"/>
            </constraints>
        </view>
    </objects>
</document>
