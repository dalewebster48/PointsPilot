<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24765" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24743"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell clipsSubviews="YES" contentMode="scaleToFill" reuseIdentifier="FlightDealCell" id="cell" customClass="FlightDealCell" customModule="PointsPilot" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="393" height="120"/>
            <autoresizingMask key="autoresizingMask"/>
            <view key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center">
                <rect key="frame" x="0.0" y="0.0" width="393" height="120"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <!-- Route row -->
                    <stackView opaque="NO" contentMode="scaleToFill" alignment="center" spacing="6" translatesAutoresizingMaskIntoConstraints="NO" id="routeStack">
                        <rect key="frame" x="16" y="12" width="361" height="20"/>
                        <subviews>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="LHR" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="originCode">
                                <rect key="frame" x="0.0" y="0.0" width="32" height="20"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="17"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="London Heathrow" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="originName">
                                <rect key="frame" x="38" y="0.0" width="113" height="20"/>
                                <fontDescription key="fontDescription" type="system" pointSize="15"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="252" text="→" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="arrow">
                                <rect key="frame" x="157" y="0.0" width="16" height="20"/>
                                <fontDescription key="fontDescription" type="system" pointSize="15"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="JFK" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="destCode">
                                <rect key="frame" x="179" y="0.0" width="26" height="20"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="17"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="New York JFK" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="destName">
                                <rect key="frame" x="211" y="0.0" width="150" height="20"/>
                                <fontDescription key="fontDescription" type="system" pointSize="15"/>
                            </label>
                        </subviews>
                    </stackView>
                    <!-- Date -->
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="15 May 2026" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="dateLabel">
                        <rect key="frame" x="16" y="38" width="100" height="16"/>
                        <fontDescription key="fontDescription" type="system" pointSize="12"/>
                    </label>
                    <!-- Points row -->
                    <stackView opaque="NO" contentMode="scaleToFill" distribution="fillEqually" spacing="8" translatesAutoresizingMaskIntoConstraints="NO" id="pointsStack">
                        <rect key="frame" x="16" y="62" width="361" height="46"/>
                        <subviews>
                            <!-- Economy -->
                            <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" alignment="center" spacing="4" translatesAutoresizingMaskIntoConstraints="NO" id="economyStack">
                                <rect key="frame" x="0.0" y="0.0" width="115" height="46"/>
                                <subviews>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Economy" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="economyHeader">
                                        <rect key="frame" x="29" y="0.0" width="57" height="16"/>
                                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                                    </label>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="12,500" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="economyPoints">
                                        <rect key="frame" x="27" y="20" width="61" height="18"/>
                                        <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="15"/>
                                    </label>
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="economyDeal">
                                        <rect key="frame" x="42" y="42" width="30" height="4"/>
                                        <constraints>
                                            <constraint firstAttribute="height" constant="4" id="edh"/>
                                            <constraint firstAttribute="width" constant="30" id="edw"/>
                                        </constraints>
                                    </view>
                                </subviews>
                            </stackView>
                            <!-- Premium -->
                            <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" alignment="center" spacing="4" translatesAutoresizingMaskIntoConstraints="NO" id="premiumStack">
                                <rect key="frame" x="123" y="0.0" width="115" height="46"/>
                                <subviews>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Premium" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="premiumHeader">
                                        <rect key="frame" x="28" y="0.0" width="59" height="16"/>
                                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                                    </label>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="33,400" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="premiumPoints">
                                        <rect key="frame" x="27" y="20" width="61" height="18"/>
                                        <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="15"/>
                                    </label>
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="premiumDeal">
                                        <rect key="frame" x="42" y="42" width="30" height="4"/>
                                        <constraints>
                                            <constraint firstAttribute="height" constant="4" id="pdh"/>
                                            <constraint firstAttribute="width" constant="30" id="pdw"/>
                                        </constraints>
                                    </view>
                                </subviews>
                            </stackView>
                            <!-- Upper -->
                            <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" alignment="center" spacing="4" translatesAutoresizingMaskIntoConstraints="NO" id="upperStack">
                                <rect key="frame" x="246" y="0.0" width="115" height="46"/>
                                <subviews>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Upper" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="upperHeader">
                                        <rect key="frame" x="37" y="0.0" width="40" height="16"/>
                                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                                    </label>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="66,800" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="upperPoints">
                                        <rect key="frame" x="27" y="20" width="61" height="18"/>
                                        <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="15"/>
                                    </label>
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="upperDeal">
                                        <rect key="frame" x="42" y="42" width="30" height="4"/>
                                        <constraints>
                                            <constraint firstAttribute="height" constant="4" id="udh"/>
                                            <constraint firstAttribute="width" constant="30" id="udw"/>
                                        </constraints>
                                    </view>
                                </subviews>
                            </stackView>
                        </subviews>
                    </stackView>
                </subviews>
            </view>
            <constraints>
                <constraint firstItem="routeStack" firstAttribute="leading" secondItem="cell" secondAttribute="leading" constant="16" id="c1"/>
                <constraint firstItem="routeStack" firstAttribute="top" secondItem="cell" secondAttribute="top" constant="12" id="c2"/>
                <constraint firstAttribute="trailing" secondItem="routeStack" secondAttribute="trailing" constant="16" id="c3"/>
                <constraint firstItem="dateLabel" firstAttribute="leading" secondItem="cell" secondAttribute="leading" constant="16" id="c4"/>
                <constraint firstItem="dateLabel" firstAttribute="top" secondItem="routeStack" secondAttribute="bottom" constant="6" id="c5"/>
                <constraint firstItem="pointsStack" firstAttribute="leading" secondItem="cell" secondAttribute="leading" constant="16" id="c6"/>
                <constraint firstItem="pointsStack" firstAttribute="top" secondItem="dateLabel" secondAttribute="bottom" constant="8" id="c7"/>
                <constraint firstAttribute="trailing" secondItem="pointsStack" secondAttribute="trailing" constant="16" id="c8"/>
                <constraint firstAttribute="bottom" secondItem="pointsStack" secondAttribute="bottom" constant="12" id="c9"/>
            </constraints>
            <connections>
                <outlet property="originCodeLabel" destination="originCode" id="o1"/>
                <outlet property="originNameLabel" destination="originName" id="o2"/>
                <outlet property="destinationCodeLabel" destination="destCode" id="o3"/>
                <outlet property="destinationNameLabel" destination="destName" id="o4"/>
                <outlet property="dateLabel" destination="dateLabel" id="o5"/>
                <outlet property="economyPointsLabel" destination="economyPoints" id="o6"/>
                <outlet property="economyDealBadge" destination="economyDeal" id="o7"/>
                <outlet property="premiumPointsLabel" destination="premiumPoints" id="o8"/>
                <outlet property="premiumDealBadge" destination="premiumDeal" id="o9"/>
                <outlet property="upperPointsLabel" destination="upperPoints" id="o10"/>
                <outlet property="upperDealBadge" destination="upperDeal" id="o11"/>
            </connections>
        </collectionViewCell>
    </objects>
</document>
