<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24765" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24743"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="TripBuilderSectionView" customModule="PointsPilot" customModuleProvider="target">
            <connections>
                <outlet property="iconImageView" destination="icon" id="o1"/>
                <outlet property="titleLabel" destination="title" id="o2"/>
                <outlet property="summaryLabel" destination="summary" id="o3"/>
                <outlet property="chevronImageView" destination="chevron" id="o4"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="root">
            <rect key="frame" x="0.0" y="0.0" width="393" height="72"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" translatesAutoresizingMaskIntoConstraints="NO" id="tapButton">
                    <rect key="frame" x="0.0" y="0.0" width="393" height="72"/>
                    <color key="tintColor" white="0.0" alpha="0.0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <connections>
                        <action selector="didTap" destination="-1" eventType="touchUpInside" id="a1"/>
                    </connections>
                </button>
                <imageView contentMode="scaleAspectFit" translatesAutoresizingMaskIntoConstraints="NO" id="icon">
                    <rect key="frame" x="16" y="16" width="24" height="24"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="24" id="iw"/>
                        <constraint firstAttribute="height" constant="24" id="ih"/>
                    </constraints>
                </imageView>
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Section Title" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="title">
                    <rect key="frame" x="52" y="14" width="297" height="22"/>
                    <fontDescription key="fontDescription" type="boldSystem" pointSize="17"/>
                </label>
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Placeholder text" numberOfLines="2" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="summary">
                    <rect key="frame" x="52" y="40" width="297" height="18"/>
                    <fontDescription key="fontDescription" type="system" pointSize="14"/>
                </label>
                <imageView contentMode="scaleAspectFit" translatesAutoresizingMaskIntoConstraints="NO" id="chevron">
                    <rect key="frame" x="361" y="24" width="16" height="24"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="16" id="cw"/>
                    </constraints>
                </imageView>
            </subviews>
            <constraints>
                <constraint firstItem="icon" firstAttribute="leading" secondItem="root" secondAttribute="leading" constant="16" id="c1"/>
                <constraint firstItem="icon" firstAttribute="top" secondItem="root" secondAttribute="top" constant="16" id="c2"/>
                <constraint firstItem="title" firstAttribute="leading" secondItem="icon" secondAttribute="trailing" constant="12" id="c3"/>
                <constraint firstItem="title" firstAttribute="top" secondItem="root" secondAttribute="top" constant="14" id="c4"/>
                <constraint firstItem="summary" firstAttribute="leading" secondItem="title" secondAttribute="leading" id="c5"/>
                <constraint firstItem="summary" firstAttribute="top" secondItem="title" secondAttribute="bottom" constant="4" id="c6"/>
                <constraint firstItem="chevron" firstAttribute="leading" secondItem="title" secondAttribute="trailing" constant="12" id="c7"/>
                <constraint firstItem="chevron" firstAttribute="leading" secondItem="summary" secondAttribute="trailing" constant="12" id="c8"/>
                <constraint firstAttribute="trailing" secondItem="chevron" secondAttribute="trailing" constant="16" id="c9"/>
                <constraint firstItem="chevron" firstAttribute="centerY" secondItem="root" secondAttribute="centerY" id="c10"/>
                <constraint firstAttribute="bottom" secondItem="summary" secondAttribute="bottom" constant="14" id="c11"/>
                <constraint firstItem="tapButton" firstAttribute="leading" secondItem="root" secondAttribute="leading" id="c12"/>
                <constraint firstItem="tapButton" firstAttribute="top" secondItem="root" secondAttribute="top" id="c13"/>
                <constraint firstAttribute="trailing" secondItem="tapButton" secondAttribute="trailing" id="c14"/>
                <constraint firstAttribute="bottom" secondItem="tapButton" secondAttribute="bottom" id="c15"/>
            </constraints>
        </view>
    </objects>
</document>
